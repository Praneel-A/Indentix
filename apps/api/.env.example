# Optional — enables persistent users in Postgres via Supabase.
# Without these, the API uses the in-memory demo store.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-side key for @supabase/supabase-js (this API is trusted).
# Prefer the service_role secret from Supabase Dashboard → Project Settings → API.
# The anon/publishable key can work only if Row Level Security is off or allows your operations on `users`.
SUPABASE_SERVICE_KEY=

# Not used by Node code — only for running SQL in Supabase SQL Editor or external tools:
# postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
