# Docker: `docker compose up -d` from repo root (postgres + redis)
DATABASE_URL="postgresql://indentix:indentix@127.0.0.1:5432/indentix"
USE_MEMORY_STORE=false
REDIS_URL="redis://127.0.0.1:6379"
# Offline dev without Docker: DATABASE_URL="file:./dev.db" + set schema provider to sqlite + USE_MEMORY_STORE=true
JWT_SECRET="change-me-min-16-chars-long"
AMOY_RPC_URL="https://rpc-amoy.polygon.technology"
RELAYER_PRIVATE_KEY="0xYOUR_RELAYER_PRIVATE_KEY"
ATTESTATION_HUB_ADDRESS="0xYOUR_DEPLOYED_ATTESTATION_HUB"
# Optional: require X-Webhook-Secret on POST /webhooks/kyc
# WEBHOOK_SECRET="shared-secret"
CHAIN_ID=80002
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
PORT=4000
